MONGO_URI=mongodb://mongo:27017/subsidy
JWT_SECRET=change-me-to-a-long-random-string-in-prod
JWT_TTL_HOURS=2

# Set MOCK_MODE=false + fill CDSE creds below to hit real Sentinel-2
MOCK_MODE=true

# --- Copernicus Data Space (real Sentinel-2) ---
# 1. Register free at https://dataspace.copernicus.eu
# 2. Create OAuth client at https://shapps.dataspace.copernicus.eu/dashboard
# 3. Paste the client_id / client_secret below.
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=
COPERNICUS_USER=
COPERNICUS_PASS=

# --- Bank / DBT (mocked in v1) ---
BANK_API_URL=http://bank-mock:9000/payouts
BANK_HMAC_KEY=dev-bank-hmac-key-change-in-prod

# --- Land Records (mocked in v1) ---
LAND_RECORDS_API=http://land-mock:9100/parcels
LAND_RECORDS_TOKEN=dev-land-token

# --- Object storage (MinIO locally, S3 in prod) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_TILES=subsidy-ndvi-dev

# --- ML model location (populated by scripts/train_model.py) ---
MODEL_PATH=/opt/models/eligibility.pkl
ISOFOREST_PATH=/opt/models/isoforest.pkl

# --- Redis (Celery broker + WebSocket event bus) ---
CELERY_BROKER=redis://redis:6379/0
CELERY_BACKEND=redis://redis:6379/1

AWS_REGION=ap-south-1
